3.Write a basic selenium + testNG program to open a browser and navigate to website. Make assertion like the website landed properly or not

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;
import org.testng.Assert;
import org.testng.annotations.AfterMethod;
import org.testng.annotations.BeforeMethod;
import org.testng.annotations.Test;

public class Assinment3 {

	WebDriver driver ;
	
		@BeforeMethod
		public void browser() {
			driver = new ChromeDriver();
	}
		@Test
		public void WebsiteLand() {
			driver.get("https://www.tutorialspoint.com/selenium/practice/alerts.php");
			String actual = driver.getCurrentUrl();
			String expected = "https://www.tutorialspoint.com/selenium/practice/alerts.php";
			Assert.assertEquals(actual, expected);
			System.out.println("actual:"+actual);
			System.out.println("expected:"+expected);
		}
		@AfterMethod
		public void teardown() {
			driver.close();
		}
}
