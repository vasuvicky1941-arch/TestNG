Write a data driven test using dataproviders when u have to give different site urls and navigate to that sites based on the data

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;
import org.testng.annotations.AfterMethod;
import org.testng.annotations.BeforeMethod;
import org.testng.annotations.DataProvider;
import org.testng.annotations.Test;

public class Assinment4 {
	WebDriver driver;
      
	@DataProvider(name="URL")
	public Object[][] Listofdata(){
		return new Object[][] {
			{"https://www.saucedemo.com/"},
			{"https://www.tutorialspoint.com/selenium/practice/alerts.php"},
			{"https://www.qa-practice.com/"}
		};
	}
	@BeforeMethod
	public void testlogin() {
		 driver = new ChromeDriver();
	}
	
	@Test(dataProvider = "URL")
	public void navigate(String URL) {
		driver.get(URL);
	}
	@AfterMethod()
	public void teardown() {
		driver.close();	
	}
}
